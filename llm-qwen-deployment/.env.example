# -----------------------------------------------------------------------
# RunPod Pod deployment (primary - used by locustfile.py, collect_metrics.py, llm_as_eval.py)
# -----------------------------------------------------------------------
# Pod 1 proxy URL  e.g. https://<POD_ID>-8000.proxy.runpod.net
POD_1_URL=https://YOUR_POD_ID-8000.proxy.runpod.net

# Pod 2 proxy URL (leave blank during Phase 1 single-pod test)
POD_2_URL=

# Model name served by vLLM on the pod
MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct

# -----------------------------------------------------------------------
# Judge LLM credentials (used by llm_as_eval.py)
# -----------------------------------------------------------------------
JUDGE_API_KEY=your_judge_api_key
JUDGE_API_BASE=https://api.deepseek.com/v1
JUDGE_MODEL=deepseek-chat




ssh root@213.173.108.103 -p 11576 -i ~/.ssh/id_ed25519

scp -P 11576 -i ~/.ssh/id_ed25519 \
    llm-qwen-deployment/custom_server.py \
    llm-qwen-deployment/requirements_pod.txt \
    root@213.173.108.103:/root/

curl -s https://sqqo9d40fbynb5-8888.proxy.runpod.net/health
curl -s https://sqqo9d40fbynb5-8888.proxy.runpod.net/v1/chat/completions \
  -H "Content-Type: application/json" \
  -d '{"messages":[{"role":"user","content":"Tell me a short moral story about sharing."}],"max_tokens":80}'